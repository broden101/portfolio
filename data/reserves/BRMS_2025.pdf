<script type="text/javascript">
    var baseLangUrl = "https://www.bumiresources.com/en";
    function doSearchData(url,dataParam,callback)
    {
         $.ajax({
                url:url,
                type:'GET',
                dataType:'json',
                data:dataParam,
                success:function(data)
                {
                    $("#searchResult").find('.modal-body').show();
                    $("#searchResult").find('.modal-header').show();
                    $("#loaderSearch").hide();
                    callback(data);

                    if(data.nextUrl)
                    {
                        $("#loadMoreSearch").attr('href',data.nextUrl);
                        $("#loadMoreSearch").parents('.load-more-search').show();
                    }else{
                        $("#loadMoreSearch").parents('.load-more-search').hide();
                    }
                },
                error:function()
                {
                     alert("Internal Server Error!");
                     $("#searchResult").modal('hide');
                }
            })
    }
    $(".searchResultField").on('keypress',function(e){
        if(e.which == 13)
        {
            var q = e.target.value;

            e.preventDefault();
            if($("#searchResult").css('display') == 'none')
            {
                $("#searchResult").modal('show');
            }

            $("#searchResult").find('.modal-body').hide();
            $("#searchResult").find('.modal-header').hide();
            $("#loaderSearch").show();

            doSearchData("https://www.bumiresources.com/en/search",{q:q},function(data){

                $("#searchResultContainer").find('.row').remove();
                $("#searchResultContainer").prepend(data.html);


                try{
                        $(".search-result").mCustomScrollbar('destroy');
                    }catch(e)
                    {
                    }

                $(".search-result").mCustomScrollbar();

            });
        }
    });
    $("#loadMoreSearch").click(function(e){
        e.preventDefault();
        doSearchData($(this).attr('href'),{},function(data){
            $("#loadMoreSearch").parents('.load-more-search').before(data.html);
        });
    })
</script>
<script>
    (function($){
        $(window).on("load",function(){
            $(".press-release-list").mCustomScrollbar();
        });
    })(jQuery);
</script>
<script type="text/javascript">
if($(".pagination").length)
{
    var paginations = $(".pagination");
    $.each(paginations,function(i,k){
        $(k).find('.active').html('<a href="javascript:void(0)">' + $(k).find('.active').text() + '</a>');

        $(k).find('.disabled').remove();

        if($(k).find("[rel=prev]").length)
        {
           $(k).find("[rel=prev]").parent().html('<a href="' + $(k).find("[rel=prev]").attr('href') + '"><i class="fa fa-angle-double-left"></i></a>')
        }else{
            $(k).prepend('<li><a href="javascript:void(0)"><i class="fa fa-angle-double-left"></i></a></li>')
        }

        if($(k).find("[rel=next]").length)
        {
           $(k).find("[rel=next]").parent().html('<a href="' + $(k).find("[rel=next]").attr('href') + '"><i class="fa fa-angle-double-right"></i></a>')
        }else{
            $(k).append('<li><a href="javascript:void(0)"><i class="fa fa-angle-double-right"></i></a></li>')
        }
    })
}
$(window).load(function(){
    if (location.hash) {
      setTimeout(function() {
        window.scrollTo(0, 0);
      }, 1);

      setTimeout(function(){
         $('html, body').animate({
                scrollTop: $(location.hash).offset().top
            }, 1000, 'swing', function () {});
      },650);

    }
})
</script>
<script>
    $(".dropdown-btn a").click(function () {
        $(this).find('.footer-plus').text(function(i, v){
           return v === '+' ? '-' : '+'
        })
    });
</script>
<script>
$( document ).ready(function() {
    $('.dropdown-btn a').on("click", function (e) {
        if ($(this).hasClass('panel-collapsed')) {
            // expand the panel
            $(this).parents('.dropdown-footer').find('.dropdown-content-footer').slideDown();
            $(this).removeClass('panel-collapsed');
        }
        else {
            // collapse the panel
            $(this).parents('.dropdown-footer').find('.dropdown-content-footer').slideUp();
            $(this).addClass('panel-collapsed');
        }
    });
});
</script>
<script>
    $(".dropdown-btn-sub a").click(function () {
        $(this).find('.footer-plus').text(function(i, v){
           return v === '+' ? '-' : '+'
        })
    });
</script>
<script>
$( document ).ready(function() {
    $('.dropdown-btn-sub a').on("click", function (e) {
        if ($(this).hasClass('panel-collapsed')) {
            // expand the panel
            $(this).parents('.dropdown-footer-sub').find('.dropdown-content-footer-sub').slideDown();
            $(this).removeClass('panel-collapsed');
        }
        else {
            // collapse the panel
            $(this).parents('.dropdown-footer-sub').find('.dropdown-content-footer-sub').slideUp();
            $(this).addClass('panel-collapsed');
        }
    });
});
</script>
<script>
/* When the user clicks on the button,
toggle between hiding and showing the dropdown content */
function myFunction() {
    document.getElementById("myDropdown").classList.toggle("show");
}
</script>
