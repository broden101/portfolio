<script type="text/javascript">
    $(document).ready(function(){
        var contents = $(".contentRemoveImageHeight");
        $.each(contents,function(i,k){
            var images = $(k).find('img');
            $.each(images,function(x,y){
                $(y).css('height','100%');
            })

            var tables = $(k).find('table');
            $.each(tables,function(x,y){
                var newElement = $("<div />").append($(y).clone()).html();

                newElement = '<div class="table-content-wrapper">' + newElement + '</div>';

                $(y).replaceWith(newElement)
            })
        });
    });
</script>
