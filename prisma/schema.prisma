generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agent {
  id              String   @id @default(uuid())
  name            String
  strategy        String
  avatar          String
  initialCapital  Float    @default(100000000)
  cash            Float    @default(100000000)
  evolutionGen    Int      @default(0)
  sellTrigger     String   @default("vwap")
  minProfitToSell Float    @default(0)
  learningLog     Json     @default("[]")
  positions       Position[]
  transactions    Transaction[]
  createdAt       DateTime @default(now())
}

model Position {
  id          Int      @id @default(autoincrement())
  agentId     String
  ticker      String
  qty         Int
  avgPrice    Float
  peakPnlPct  Float    @default(0)
  openedAt    DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, ticker])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  agentId     String
  ticker      String
  side        String
  qty         Int
  price       Float
  reason      String
  pnl         Float?
  executedAt  DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}
